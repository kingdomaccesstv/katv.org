---
layout: layouts/base.njk
---
{% set activeTitle = title or vod.title %}

<div class="page-title-full-width-container" id="page-title-full-width-container">
  <header role="banner" id="page-title" class="container page-title-container">
    <h1 class="page-title">{{ activeTitle }}</h1>
  </header>
</div>

<main role="main" class="main-container container">
  <article class="vod is-promoted full clearfix node">
    <div class="content">
      <div class="layout layout--twocol-section">
        
        <!-- Video Player Column -->
        <div class="layout__region layout__region--first">
          <div class="ratio ratio-16x9">
            {% if vod.videoSource == 'vimeo' %}
              <iframe 
                class="embed-responsive-item" 
                src="https://player.vimeo.com/video/{{ vod.videoId }}?autoplay=1" 
                title="{{ activeTitle }} Video Player"
                allow="autoplay; fullscreen; picture-in-picture; clipboard-write" 
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen>
              </iframe>
            {% elif vod.videoSource == 'archive.org' %}
              <iframe 
                class="embed-responsive-item" 
                src="https://archive.org/embed/{{ vod.videoId }}?autoplay=1" 
                title="{{ activeTitle }} Video Player"
                allow="autoplay; fullscreen; picture-in-picture" 
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen>
              </iframe>
            {% else %}
              <p style="padding: 30px; text-align: center; color: white;">Video embed unavailable</p>
            {% endif %}
          </div>
        </div>
        
        <!-- Metadata Sidebar Column -->
        <div class="layout__region layout__region--second">
          
          {% if vod.location %}
          <div class="field field--name-field-event-location field--type-string field--label-above">
            <div class="field__label">Location</div>
            <div class="field__item">{{ vod.location }}</div>
          </div>
          {% endif %}

          {% if vod.date %}
          <div class="field field--name-field-event-date field--type-datetime field--label-above">
            <div class="field__label">Date</div>
            <div class="field__item">{{ vod.date | postDate }}</div>
          </div>
          {% endif %}

          {% if vod.categories and vod.categories.length > 0 %}
          <div class="field field--name-field-program-category field--type-entity-reference field--label-above">
            <div class="field__label">Categories</div>
            <div class="field__items">
              {% for cat in vod.categories %}
                <div class="field__item">
                  <a href="{{ cat.path | categoryUrl }}/">{{ cat.name }}</a>
                </div>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          {% if vod.year %}
          <div class="field field--name-field-content-year field--type-entity-reference field--label-hidden">
            <div class="field__item">
              <a href="/vod/year/{{ vod.year }}/">{{ vod.year }}</a>
            </div>
          </div>
          {% endif %}



          <!-- Social Share -->
          <div class="share-container">
            <span class="share-label">Share this video</span>
            <div class="share-list">
              <!-- Generic Web Share / Copy Link -->
              <button id="web-share-btn" class="share-btn share-btn--webshare" title="Share or Copy Link" aria-label="Share or Copy Link">
                <svg viewBox="0 0 24 24">
                  <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92c0-1.61-1.31-2.92-2.92-2.92z"/>
                </svg>
              </button>
              
              <!-- Facebook -->
              <a href="https://www.facebook.com/sharer/sharer.php?u=https://katv.org{{ vod.path }}" target="_blank" rel="noopener" class="share-btn share-btn--facebook" title="Share on Facebook" aria-label="Share on Facebook">
                <svg viewBox="0 0 24 24">
                  <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/>
                </svg>
              </a>

              <!-- LinkedIn -->
              <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://katv.org{{ vod.path }}" target="_blank" rel="noopener" class="share-btn share-btn--linkedin" title="Share on LinkedIn" aria-label="Share on LinkedIn">
                <svg viewBox="0 0 24 24">
                  <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
                </svg>
              </a>

              <!-- WhatsApp -->
              <a href="https://api.whatsapp.com/send?text={{ activeTitle | urlencode }}%20https://katv.org{{ vod.path }}" target="_blank" rel="noopener" class="share-btn share-btn--whatsapp" title="Share on WhatsApp" aria-label="Share on WhatsApp">
                <svg viewBox="0 0 24 24">
                  <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.5-5.729-1.448L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.863-9.855.001-2.63-1.024-5.101-2.885-6.964C16.593 1.928 14.12 1.9 11.522 1.9c-5.437 0-9.863 4.42-9.866 9.856-.002 1.762.463 3.483 1.347 5.024L2.002 21.53l4.645-1.216-.001-.001zm11.66-7.24c-.31-.156-1.84-.908-2.12-.101-.284.802-.853 1.01-1.043 1.22-.19.208-.38.23-.69.074-1.395-.698-2.42-1.464-3.23-2.86-.208-.356-.02-.549.152-.722.155-.156.31-.363.466-.543.155-.181.208-.31.31-.518.104-.207.052-.39-.026-.543-.078-.155-.69-1.67-.944-2.285-.247-.597-.5-.515-.69-.525-.18-.01-.387-.01-.593-.01-.207 0-.543.078-.827.39-.283.31-1.084 1.06-1.084 2.59 0 1.528 1.11 3.003 1.265 3.21.155.207 2.185 3.337 5.293 4.678.74.32 1.317.51 1.768.653.743.236 1.42.203 1.954.124.595-.088 1.84-.75 2.1-1.451.26-.7.26-1.3.18-1.423-.076-.123-.283-.2-.593-.356z"/>
                </svg>
              </a>

              <!-- Email -->
              <a href="mailto:?subject={{ activeTitle | urlencode }}&body=Check%20out%20this%20video%20on%20Kingdom%20Access%20TV%3A%20https%3A%2F%2Fkatv.org{{ vod.path }}" class="share-btn share-btn--email" title="Share via Email" aria-label="Share via Email">
                <svg viewBox="0 0 24 24">
                  <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                </svg>
              </a>
            </div>
          </div>

          <script>
            document.addEventListener('DOMContentLoaded', () => {
              const shareBtn = document.getElementById('web-share-btn');
              if (!shareBtn) return;
              
              const shareData = {
                title: `{{ activeTitle | safe }}`,
                text: `Watch {{ activeTitle | safe }} on Kingdom Access TV.`,
                url: 'https://katv.org{{ vod.path }}'
              };

              shareBtn.addEventListener('click', async () => {
                if (navigator.share) {
                  try {
                    await navigator.share(shareData);
                  } catch (err) {
                    console.error('Error sharing:', err);
                  }
                } else {
                  try {
                    await navigator.clipboard.writeText(shareData.url);
                    const originalTitle = shareBtn.getAttribute('title');
                    shareBtn.setAttribute('title', 'Link Copied!');
                    shareBtn.classList.add('share-btn--copied');
                    
                    setTimeout(() => {
                      shareBtn.setAttribute('title', originalTitle);
                      shareBtn.classList.remove('share-btn--copied');
                    }, 2000);
                  } catch (err) {
                    console.error('Failed to copy link: ', err);
                  }
                }
              });
            });
          </script>

        </div>

      </div>
    </div>
  </article>
</main>
