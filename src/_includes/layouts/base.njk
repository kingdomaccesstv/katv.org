<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | Kingdom Access TV</title>
  
  <meta name="description" content="{{ description or 'Kingdom Access Television (KATV) public access television site in Saint Johnsbury, VT' }}" />
  {% if page.url %}
  <link rel="canonical" href="https://katv.org{{ page.url }}" />
  {% endif %}

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://katv.org{{ page.url }}" />
  <meta property="og:title" content="{{ title }} | Kingdom Access TV" />
  <meta property="og:description" content="{{ description or 'Kingdom Access Television (KATV) public access television site in Saint Johnsbury, VT' }}" />
  <meta property="og:image" content="https://katv.org{{ teaserImage or '/assets/images/banner-studio-1.jpg' }}" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content="https://katv.org{{ page.url }}" />
  <meta property="twitter:title" content="{{ title }} | Kingdom Access TV" />
  <meta property="twitter:description" content="{{ description or 'Kingdom Access Television (KATV) public access television site in Saint Johnsbury, VT' }}" />
  <meta property="twitter:image" content="https://katv.org{{ teaserImage or '/assets/images/banner-studio-1.jpg' }}" />

  <!-- Favicons -->
  <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicons/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicons/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/favicons/apple-touch-icon.png" />

  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body>
  <div class="dxpr-theme-boxed-container">
    
    <!-- Secondary Header (Live Ticker) -->
    <header id="secondary-header" class="dxpr-theme-secondary-header">
      <div id="liveOnKatv">
        <span class="ticker-item" id="ticker-live"><strong>LIVE ON KATV</strong></span>
        <span class="ticker-item" id="ticker-ch2"><strong>Channel 192:</strong> Loading...</span>
        <span class="ticker-item" id="ticker-ch6"><strong>Channel 194:</strong> Loading...</span>
      </div>
    </header>

    <!-- Main Navigation Header -->
    <header class="dxpr-theme-header" id="navbar">
      <div class="navbar-container">
        <a class="navbar-brand" href="/">Kingdom Access TV</a>
        <button class="navbar-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <span class="icon-bar"></span>
          <span class="icon-bar"></span>
          <span class="icon-bar"></span>
        </button>
        <nav role="navigation" id="main-menu">
          <ul class="menu nav">
            <li class="{% if page.url == '/vod/' or page.url.startsWith('/vod/') %}active{% endif %}">
              <a href="/vod/">On Demand</a>
            </li>
            <li class="{% if page.url == '/live/' %}active{% endif %}">
              <a href="/live/">Watch Live</a>
            </li>
            <li class="{% if page.url == '/bulletin-board/' %}active{% endif %}">
              <a href="/bulletin-board/">Bulletin Board</a>
            </li>
            <li class="{% if page.url == '/schedule/' %}active{% endif %}">
              <a href="/schedule/">Schedule</a>
            </li>
            <li class="{% if page.url == '/search/' %}active{% endif %}">
              <a href="/search/">Search</a>
            </li>
            <li class="{% if page.url == '/about/' %}active{% endif %}">
              <a href="/about/">About</a>
            </li>
            <li>
              <a href="https://www.paypal.com/donate/?hosted_button_id=ETA6KVWW54P6L" target="_blank">Support Us</a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- Main Content Area -->
    {{ content | safe }}

    <!-- Footer -->
    <footer class="dxpr-theme-footer">
      <p>Copyright © 2026 Kingdom Access Television, Inc. • <a href="/jobs/">Jobs</a> • <a href="https://www.paypal.com/donate/?hosted_button_id=ETA6KVWW54P6L" target="_blank" style="font-weight: bold">Support KATV</a></p>
      <p style="margin-top: 10px; font-size: 0.85rem; opacity: 0.8;">515 Bay Street, Suite 202, Saint Johnsbury, VT 05819 • Phone (802) 751-8103</p>
    </footer>

  </div>

  <!-- Dynamic Live Ticker Script -->
  <script>
    (function() {
      let now = new Date();
      let nowEpoch = Math.floor(Date.now() / 1000);
      let nowPlayingData = {};
      let forceRefresh = false;
      let channelMap = { 2: 192, 6: 194 };

      let startMinutes = [0, 1, 29, 30, 59];
      if (startMinutes.includes(now.getMinutes())) {
        forceRefresh = true;
      }

      async function fetchShows(channelId) {
        let fetchUrl = `https://frontdoor.katv.org/cablecastapi/v1/scheduleItems?channel=${channelId}&end=${now.toISOString()}&include=show&include_cg_exempt=false&page_size=1&start=${now.toISOString()}`;

        try {
          let response = await fetch(fetchUrl);
          return await response.json();
        } catch (error) {
          console.error("Could not get show information from Cablecast channel " + channelId);
          return null;
        }
      }

      async function processChannelData(channelId) {
        let showData = await fetchShows(channelId);
        let channel = channelMap[channelId];
        let text = "Community Bulletin Board";
        if (showData && showData.shows && showData.shows.length > 0) {
          text = showData.shows[0]["cgTitle"];
        }
        let el = document.getElementById(`ticker-ch${channelId}`);
        if (el) {
          el.innerHTML = `<strong>Channel ${channel}:</strong> ${text}`;
        }
        return text;
      }

      function updateTextFromCache(channelId, input) {
        let value = input[`nowPlayingCh${channelId}`];
        let channel = channelMap[channelId];
        let text = value || "Community Bulletin Board";
        let el = document.getElementById(`ticker-ch${channelId}`);
        if (el) {
          el.innerHTML = `<strong>Channel ${channel}:</strong> ${text}`;
        }
        return text;
      }

      let activeMobileIndex = 0;
      let tickerInterval = null;

      function shrinkTextToFit(element) {
        element.style.fontSize = ''; // Reset to default style
        const container = document.getElementById('secondary-header');
        if (!container) return;
        const maxW = container.clientWidth - 30; // 30px padding total
        let fontSize = parseFloat(window.getComputedStyle(element).fontSize);
        const minFontSize = 8;
        
        while (element.scrollWidth > maxW && fontSize > minFontSize) {
          fontSize -= 0.5;
          element.style.fontSize = fontSize + 'px';
        }
      }

      function updateTicker() {
        const isMobile = window.innerWidth <= 768;
        const items = document.querySelectorAll('.ticker-item');
        
        if (isMobile) {
          items.forEach((item, idx) => {
            if (idx === activeMobileIndex) {
              item.style.display = 'inline-block';
              shrinkTextToFit(item);
            } else {
              item.style.display = 'none';
              item.style.fontSize = '';
            }
          });
        } else {
          items.forEach(item => {
            item.style.display = 'inline-block';
            item.style.fontSize = '';
          });
        }
      }

      function startTickerRotation() {
        if (tickerInterval) clearInterval(tickerInterval);
        tickerInterval = setInterval(() => {
          if (window.innerWidth <= 768) {
            activeMobileIndex = (activeMobileIndex + 1) % 3;
            updateTicker();
          }
        }, 5000);
      }

      function initTicker() {
        updateTicker();
        startTickerRotation();
        window.addEventListener('resize', () => {
          updateTicker();
        });
      }

      if (sessionStorage.nowPlayingData) {
        try {
          nowPlayingData = JSON.parse(sessionStorage.nowPlayingData);
        } catch(e) {
          nowPlayingData = {};
        }
      }

      if (nowPlayingData.lastRefresh && ((nowPlayingData.lastRefresh + 300) > nowEpoch) && !forceRefresh) {
        updateTextFromCache(2, nowPlayingData);
        updateTextFromCache(6, nowPlayingData);
        initTicker();
      } else {
        initTicker(); // initialize with loading state
        (async function () {
          let show2 = await processChannelData(2);
          let show6 = await processChannelData(6);
          let nowPlayingData = {
            nowPlayingCh2: show2 || "Community Bulletin Board",
            nowPlayingCh6: show6 || "Community Bulletin Board",
            lastRefresh: nowEpoch
          };
          sessionStorage.setItem('nowPlayingData', JSON.stringify(nowPlayingData));
          updateTicker();
        }());
      }
    })();
  </script>

  <!-- Mobile Navbar Toggle Script -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const toggle = document.querySelector('.navbar-toggle');
      const menu = document.getElementById('main-menu');
      if (toggle && menu) {
        toggle.addEventListener('click', function() {
          const isOpen = toggle.classList.toggle('open');
          menu.classList.toggle('open');
          toggle.setAttribute('aria-expanded', isOpen);
        });
      }
    });
  </script>
</body>
</html>
